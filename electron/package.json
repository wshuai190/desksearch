{
  "name": "desksearch",
  "productName": "DeskSearch",
  "version": "0.5.0",
  "description": "Private semantic search engine for your local files",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "author": "DeskSearch",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.desksearch.app",
    "productName": "DeskSearch",
    "directories": {
      "output": "../dist/electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "build-config.js",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "DeskSearch",
      "iconSize": 80,
      "contents": [
        {
          "x": 170,
          "y": 200
        },
        {
          "x": 430,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "icon": "assets/icon.png"
    },
    "extraResources": [
      {
        "from": "../dist/desksearch-backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../src/ui/dist",
        "to": "ui",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}